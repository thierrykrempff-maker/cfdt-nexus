{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfdt-nexus.local/schema/bulletin.schema.json",
  "title": "CFDT Nexus - Bulletin de veille",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "edition_date",
    "edition_type",
    "title",
    "editorial_note",
    "items",
    "items_to_verify",
    "validated_by",
    "validated_at",
    "publication_allowed"
  ],
  "properties": {
    "id": { "type": "string" },
    "edition_date": { "type": "string", "format": "date" },
    "edition_type": { "type": "string", "enum": ["lundi", "mercredi", "vendredi", "exceptionnel"] },
    "title": { "type": "string" },
    "editorial_note": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["veille_item_id", "heading", "summary", "source_label", "confidence", "action"],
        "properties": {
          "veille_item_id": { "type": "string" },
          "heading": { "type": "string" },
          "summary": { "type": "string" },
          "source_label": { "type": "string" },
          "confidence": { "type": "string", "enum": ["fort", "moyen", "faible"] },
          "action": { "type": "string" }
        }
      }
    },
    "items_to_verify": { "type": "array", "items": { "type": "string" } },
    "validated_by": { "type": ["string", "null"] },
    "validated_at": { "type": ["string", "null"], "format": "date-time" },
    "publication_allowed": { "type": "boolean" }
  }
}

