    },
    {
      "source": "contradictions",
      "targets": [
        "Evidence",
        "Finding"
      ]
    },
    {
      "source": "missing_information",
      "targets": [
        "Evidence",
        "Finding"
      ]
    },
    {
      "source": "risks",
      "targets": [
        "Evidence",
        "Finding"
      ]
    },
    {
      "source": "recommendations",
      "targets": [
        "Recommendation"
      ]
    },
    {
      "source": "proposed_actions",
      "targets": [
        "Recommendation"
      ]
    },
    {
      "source": "KnowledgeSource",
      "targets": [
        "DocumentReference",
        "Provenance"
      ]
    },
    {
      "source": "SourceEvidence",
      "targets": [
        "Evidence"
      ]
    }
  ],
  "protocols": [
    "ExecutableEngine",
    "FactProducer",
    "EvidenceProducer",
    "FindingProducer",
    "RecommendationProducer"
  ]
