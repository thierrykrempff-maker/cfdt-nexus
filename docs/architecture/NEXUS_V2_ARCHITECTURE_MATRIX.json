  "findings": [
    {
      "id": "V2-REV-001",
      "severity": "P1",
      "status": "RESOLVED",
      "title": "Cross-package imports bypassed public APIs",
      "proof": "test_cross_package_imports_use_only_public_package_apis failed with eight violations",
      "correction": "Export safe metadata helpers and label normalization from public facades, then import only from package roots"
    },
    {
      "id": "V2-REV-002",
      "severity": "P1",
      "status": "RESOLVED",
      "title": "Public ingestion status vocabulary could not represent tracker lifecycle states",
      "proof": "test_closed_decision_is_not_reported_as_open raised ValueError for MetadataStatus('OPEN')",
      "correction": "Add OPEN, IN_PROGRESS, CLOSED and CANCELLED to MetadataStatus"
    },
    {
      "id": "V2-REV-003",
      "severity": "P1",
      "status": "RESOLVED",
      "title": "Final meeting result depended on metadata insertion order",
      "proof": "test_insertion_order_does_not_change_final_result failed",
      "correction": "Include document status in the metadata deduplication key"
    },
    {
      "id": "V2-REV-004",
      "severity": "P2",
      "status": "KNOWN_LIMITATION",
      "title": "Deduplication key deliberately excludes normalized title",
      "impact": "Distinct sources sharing every keyed metadata field may still be reconciled",
      "recommendation": "Change only after a documented identity case demonstrates the need"
    },
    {
      "id": "V2-REV-005",
      "severity": "P3",
      "status": "ACCEPTED",
      "title": "Layer-specific document projections and serialization helpers are repetitive",
      "impact": "Small amount of boilerplate",
      "recommendation": "Keep separate to preserve least-data boundaries and avoid additional coupling"
    }
  ],
  "integration_scenarios": [
