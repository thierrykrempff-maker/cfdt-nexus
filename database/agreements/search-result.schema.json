{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfdt-nexus.local/schema/agreements-search-result.schema.json",
  "title": "Bible Accords Sarralbe - Search Result V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "question",
    "provisional_answer",
    "confidence_level",
    "sources_used",
    "points_to_verify",
    "possible_conflicts",
    "potentially_linked_newer_document",
    "recommended_human_action"
  ],
  "properties": {
    "question": { "type": "string" },
    "provisional_answer": { "type": "string" },
    "confidence_level": { "type": "string", "enum": ["fort", "moyen", "faible"] },
    "sources_used": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["document", "page", "article_or_section", "excerpt", "match_score", "source_layer"],
        "properties": {
          "document": { "type": "string" },
          "document_id": { "type": "string" },
          "document_type": { "type": ["string", "null"] },
          "source_layer": {
            "type": "string",
            "enum": ["accord_entreprise", "convention_collective", "code_travail", "jurisprudence", "prudhommes", "pratique", "autre"]
          },
          "idcc": { "type": ["string", "null"] },
          "version": { "type": ["string", "null"] },
          "page": { "type": ["integer", "null"] },
          "article_or_section": { "type": ["string", "null"] },
          "location": { "type": "string" },
          "excerpt": { "type": "string" },
          "match_score": { "type": "number" },
          "ranking_profile": { "type": ["string", "null"] },
          "ranking_reasons": { "type": "array", "items": { "type": "string" } },
          "chunk_id": { "type": "string" },
          "source_quality_warning": { "type": ["string", "null"] }
        }
      }
    },
    "points_to_verify": { "type": "array", "items": { "type": "string" } },
    "possible_conflicts": { "type": "array", "items": { "type": "string" } },
    "potentially_linked_newer_document": { "type": "array", "items": { "type": "string" } },
    "recommended_human_action": { "type": "string" }
  }
}
