{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfdt-nexus.local/schema/agreements-index.schema.json",
  "title": "Bible Accords Sarralbe - Document Metadata V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_id",
    "filename",
    "extension",
    "relative_path",
    "file_size",
    "modified_at",
    "sha256",
    "change_status",
    "extraction_status",
    "ocr_required",
    "document_type",
    "primary_topic",
    "secondary_topics",
    "confidentiality_level",
    "indexed_at",
    "last_checked_at"
  ],
  "properties": {
    "document_id": { "type": "string" },
    "filename": { "type": "string" },
    "extension": { "type": "string" },
    "relative_path": { "type": "string" },
    "file_size": { "type": "integer" },
    "modified_at": { "type": "string" },
    "sha256": { "type": "string" },
    "change_status": {
      "type": "string",
      "enum": ["NEW", "MODIFIED", "UNCHANGED", "MISSING", "DUPLICATE_EXACT"]
    },
    "extraction_status": {
      "type": "string",
      "enum": ["PENDING", "EXTRACTION_OK", "EXTRACTION_A_VERIFIER", "OCR_REQUIRED", "ERROR", "UNSUPPORTED"]
    },
    "ocr_required": { "type": "boolean" },
    "document_type": { "type": "string" },
    "primary_topic": { "type": "string" },
    "secondary_topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidentiality_level": {
      "type": "string",
      "enum": ["private", "confidential", "internal", "public-validated"]
    },
    "indexed_at": { "type": ["string", "null"] },
    "last_checked_at": { "type": "string" }
  }
}

