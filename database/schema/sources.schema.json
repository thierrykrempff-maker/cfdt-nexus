{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfdt-nexus.local/schema/sources.schema.json",
  "title": "CFDT Nexus Source Metadata V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "nom",
    "type",
    "confidentialite",
    "emplacement",
    "autoriseIndexation",
    "dateAjout",
    "derniereVerification"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
    },
    "nom": {
      "type": "string",
      "minLength": 3,
      "maxLength": 180
    },
    "type": {
      "type": "string",
      "enum": [
        "dossier local",
        "cloud privé",
        "site officiel",
        "export manuel",
        "archive privée"
      ]
    },
    "confidentialite": {
      "type": "string",
      "enum": [
        "public",
        "interne",
        "confidentiel"
      ]
    },
    "emplacement": {
      "type": "string",
      "minLength": 1,
      "description": "Chemin privé, URL officielle ou description d'emplacement. Les chemins privés ne doivent pas être publics."
    },
    "description": {
      "type": "string",
      "maxLength": 1200
    },
    "proprietaire": {
      "type": "string",
      "maxLength": 120
    },
    "autoriseIndexation": {
      "type": "boolean",
      "description": "Autorise seulement l'indexation de métadonnées expurgées, pas le stockage du document réel dans GitHub."
    },
    "agentsAutorises": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "document-intelligence-center",
          "cycle-cse",
          "defenseur-syndical",
          "paie",
          "cssct",
          "convention-chimie",
          "veille-juridique",
          "communication",
          "routeur-core"
        ]
      },
      "uniqueItems": true,
      "default": []
    },
    "dateAjout": {
      "type": "string",
      "format": "date-time"
    },
    "derniereVerification": {
      "type": "string",
      "format": "date"
    },
    "notesSecurite": {
      "type": "string",
      "maxLength": 1200
    }
  }
}
